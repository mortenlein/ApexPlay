{
  "name": "apex-play",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/setup-db.js && next dev -p 4001",
    "dev:e2e": "node scripts/dev-e2e.js",
    "db:prepare": "node scripts/setup-db.js",
    "build": "node scripts/setup-db.js && npx prisma generate && node scripts/clean-next.js && next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:cs2-webhook": "node scripts/test-cs2-webhook.js",
    "postinstall": "prisma generate",
    "bot": "ts-node -r dotenv/config scripts/discord-bot.ts"
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.4.1",
    "@tanstack/react-query": "^5.90.21",
    "bufferutil": "^4.1.0",
    "discord-api-types": "^0.38.44",
    "discord.js": "^14.26.0",
    "dotenv": "^17.4.0",
    "erlpack": "^0.1.4",
    "lucide-react": "^0.477.0",
    "next": "14.2.24",
    "next-auth": "^4.24.13",
    "next-auth-steam": "^0.4.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "sharp": "^0.33.5",
    "utf-8-validate": "^6.0.6",
    "uuid": "^13.0.0",
    "zlib-sync": "^0.1.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.24",
    "postcss": "^8.4.49",
    "prisma": "^6.4.1",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.3.0",
    "typescript": "^5",
    "typescript-transform-paths": "^3.5.6"
  }
}
