generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Dynamically replaced by scripts/setup-db.js on Netlify
  url      = env("DATABASE_URL")
}

model Tournament {
  id              String   @id @default(uuid())
  name            String
  game            String   @default("CS2") // CS2, FORTNITE, VALORANT, etc
  category        String   @default("BRACKET") // BRACKET, BATTLE_ROYALE
  type            String   // DEPRECATED: use format, keeping for backward compat
  format          String   @default("SINGLE_ELIMINATION") // SINGLE_ELIMINATION, DOUBLE_ELIMINATION
  teamSize        Int      @default(5) // 2 for 2v2, 5 for 5v5
  bo3StartRound   Int?     // Round number where BO3 starts
  bo5StartRound   Int?     // Round number where BO5 starts
  hasThirdPlace   Boolean  @default(false)
  matches         Match[]
  teams           Team[]
  scoreboard      ScoreboardEntry[]
  createdAt       DateTime @default(now())
}

model Team {
  id           String      @id @default(uuid())
  name         String
  logoUrl      String?
  seed         Int?
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId String
  players      Player[]
  
  matchHome    Match[]     @relation("HomeTeam")
  matchAway    Match[]     @relation("AwayTeam")
  scoreboard   ScoreboardEntry[]
}

model Player {
  id        String  @id @default(uuid())
  name      String
  seating   String? // e.g., "A1"
  steamId   String? // SteamID64
  isOnline  Boolean @default(false)
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String
}

model Match {
  id           String      @id @default(uuid())
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId String
  
  homeTeam     Team?       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  homeTeamId   String?
  awayTeam     Team?       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  awayTeamId   String?

  homeScore    Int         @default(0) // Series Score
  awayScore    Int         @default(0) // Series Score
  mapScores    String      @default("[]") // JSON string of map scores, e.g. [{"home": 13, "away": 11}]
  
  bestOf       Int         @default(1) // 1, 3, or 5 maps
  scoreLimit   Int         @default(1) // Points needed to win

  winnerId     String?     
  
  bracketType  String      @default("WINNERS") // WINNERS, LOSERS, THIRD_PLACE
  round        Int         // 1 = Quarter Finals, 2 = Semi, etc.
  matchOrder   Int         
  nextMatchId  String?     // ID of the next match the winner advances to
  loserNextMatchId String? // ID of the next match the loser advances to (for Double Elim)
  
  serverIp       String?   // Game server IP for "Join Server" button
  serverPort     String?   // Game server port
  serverPassword String?   // Server password

  status       String      @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, LIVE
}

model ScoreboardEntry {
  id           String      @id @default(uuid())
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId String
  
  team         Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId       String
  
  kills        Int         @default(0)
  placement    Int         @default(0)
  points       Int         @default(0)
  
  updatedAt    DateTime    @updatedAt

  @@unique([tournamentId, teamId])
}
