generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tournament {
  id                 String            @id @default(uuid())
  name               String
  game               String            @default("CS2")
  category           String            @default("BRACKET")
  type               String
  format             String            @default("SINGLE_ELIMINATION")
  teamSize           Int               @default(5)
  bo3StartRound      Int?
  bo5StartRound      Int?
  hasThirdPlace      Boolean           @default(false)
  steamSignupEnabled Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now()) @updatedAt
  rosterLocked       Boolean           @default(false)
  auditLogs          AuditLog[]
  matches            Match[]
  notifications      NotificationLog[]
  players            Player[]
  scoreboard         ScoreboardEntry[]
  teams              Team[]
}

model Team {
  id           String            @id @default(uuid())
  name         String
  logoUrl      String?
  seed         Int?
  tournamentId String
  inviteCode   String?           @unique
  updatedAt    DateTime          @default(now()) @updatedAt
  matchHome    Match[]           @relation("HomeTeam")
  matchAway    Match[]           @relation("AwayTeam")
  players      Player[]
  scoreboard   ScoreboardEntry[]
  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Player {
  id          String  @id @default(uuid())
  name        String
  nickname    String?
  countryCode String?
  seating     String?
  steamId     String?
  isOnline    Boolean @default(false)
  isLeader    Boolean @default(false)
  teamId      String
  tournamentId String
  userId      String?
  updatedAt   DateTime @default(now()) @updatedAt
  team        Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tournament  Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user        User?   @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  steamId       String?   @unique
  accounts      Account[]
  sessions      Session[]
  players       Player[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Match {
  id               String     @id @default(uuid())
  tournamentId     String
  homeTeamId       String?
  awayTeamId       String?
  homeScore        Int        @default(0)
  awayScore        Int        @default(0)
  mapScores        String     @default("[]")
  bestOf           Int        @default(1)
  scoreLimit       Int        @default(1)
  winnerId         String?
  bracketType      String     @default("WINNERS")
  round            Int
  matchOrder       Int
  nextMatchId      String?
  loserNextMatchId String?
  serverIp         String?
  serverPort       String?
  serverPassword   String?
  status           String     @default("PENDING")
  updatedAt        DateTime   @default(now()) @updatedAt
  tournament       Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  homeTeam         Team?      @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam         Team?      @relation("AwayTeam", fields: [awayTeamId], references: [id])
}

model ScoreboardEntry {
  id           String     @id @default(uuid())
  tournamentId String
  teamId       String
  kills        Int        @default(0)
  placement    Int        @default(0)
  points       Int        @default(0)
  updatedAt    DateTime   @updatedAt
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
}

model NotificationLog {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String?
  tournamentId String?
  createdAt   DateTime @default(now())
  tournament  Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String      @id @default(cuid())
  tournamentId String?
  entityType  String
  entityId    String
  action      String
  summary     String
  actor       String?
  metadata    String?
  createdAt   DateTime    @default(now())
  tournament  Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}
